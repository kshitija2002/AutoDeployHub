name: Docker Build & Deploy

on:
  push:
    branches: [ "main" ]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v3

      - name: Build Docker Image
        run: docker build -t autodeployhub .

      - name: Run Docker Container
        run: docker run -d -p 3000:3000 autodeployhub
